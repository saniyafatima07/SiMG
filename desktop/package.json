{
    "name": "dicom-guardian",
    "version": "1.0.0",
    "description": "DICOM Guardian Desktop Application",
    "main": "dist-ts/main.js",
    "scripts": {
        "build:ts": "tsc",
        "build:react": "webpack --config webpack.config.js",
        "build": "npm run build:ts && npm run build:react",
        "build:cpp": "bash scripts/build_cpp.sh",
        "start": "npm run build && ELECTRON_DISABLE_SANDBOX=1 electron dist-ts/main.js",
        "dev": "ELECTRON_DISABLE_SANDBOX=1 electron dist-ts/main.js",
        "dist": "electron-builder --linux"
    },
    "dependencies": {
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/preset-env": "^7.29.0",
        "@babel/preset-react": "^7.28.5",
        "@types/node": "^20.0.0",
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "babel-loader": "^10.1.1",
        "electron": "^28.0.0",
        "electron-builder": "^24.0.0",
        "html-webpack-plugin": "^5.6.6",
        "ts-loader": "^9.5.4",
        "ts-node": "^10.0.0",
        "typescript": "^5.0.0",
        "webpack": "^5.105.4",
        "webpack-cli": "^6.0.1"
    },
    "build": {
        "appId": "com.dicomguardian.app",
        "productName": "DICOM Guardian",
        "directories": {
            "output": "dist"
        },
        "extraFiles": [
            {
                "from": "../fingerprint/anchor/build/anchor",
                "to": "fingerprint/anchor/build/anchor"
            },
            {
                "from": "../fingerprint/verifier/build/verifier",
                "to": "fingerprint/verifier/build/verifier"
            },
            {
                "from": "../sandbox/verification-enclosure/run.sh",
                "to": "sandbox/verification-enclosure/run.sh"
            },
            {
                "from": "../converter",
                "to": "converter"
            },
            {
                "from": "../keys/public.pem",
                "to": "keys/public.pem"
            }
        ],
        "linux": {
            "target": [
                "AppImage",
                "deb"
            ]
        }
    }
}